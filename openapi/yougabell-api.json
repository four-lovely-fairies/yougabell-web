{
  "openapi": "3.0.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "AppController_getHello",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "tags": ["App"]
      }
    },
    "/onboarding/complete": {
      "post": {
        "description": "Parent 정보 + Child[] + 앱 사용 시간대[]를 단일 atomic 트랜잭션으로 적용. 이미 완료된 사용자는 409.",
        "operationId": "OnboardingController_complete",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CompleteOnboardingDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "온보딩 일괄 완료",
        "tags": ["onboarding"]
      }
    },
    "/me": {
      "get": {
        "description": "User 본인 + children + appUsageSlots 포함. onboardedAt이 null이면 미완료.",
        "operationId": "UsersController_getMe",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "본인 정보 조회",
        "tags": ["users"]
      }
    },
    "/admin/users": {
      "get": {
        "description": "온보딩 완료자 기본. q(이름 LIKE) / page / limit / onboarded 필터.",
        "operationId": "AdminController_listUsers",
        "parameters": [
          {
            "name": "onboarded",
            "required": false,
            "in": "query",
            "description": "온보딩 필터. default true (완료자만)",
            "schema": {
              "type": "string",
              "enum": ["true", "false", "all"]
            }
          },
          {
            "name": "q",
            "required": false,
            "in": "query",
            "description": "이름 LIKE 검색",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "required": false,
            "in": "query",
            "description": "1-based",
            "schema": {
              "minimum": 1,
              "default": 1,
              "type": "number"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "페이지당 항목",
            "schema": {
              "minimum": 1,
              "maximum": 100,
              "default": 20,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "사용자 목록 (운영자)",
        "tags": ["admin"]
      }
    },
    "/admin/weekly-reports/generate": {
      "post": {
        "description": "지정한 주차 또는 직전 완료 주차의 주간 리포트를 자녀별로 생성한다.",
        "operationId": "AdminController_generateWeeklyReports",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GenerateWeeklyReportsDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "주간 리포트 수동 생성 (운영자)",
        "tags": ["admin"]
      }
    },
    "/weekly-reports/current": {
      "get": {
        "operationId": "WeeklyReportsController_getCurrent",
        "parameters": [
          {
            "name": "childId",
            "required": false,
            "in": "query",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "name": "weekStart",
            "required": false,
            "in": "query",
            "description": "조회할 주차의 월요일. YYYY-MM-DD",
            "schema": {
              "example": "2026-05-04",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WeeklyReportCurrentResponseDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": ["weekly-reports"]
      }
    },
    "/weekly-reports/{id}": {
      "get": {
        "operationId": "WeeklyReportsController_getById",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/WeeklyReportDetailDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": ["weekly-reports"]
      }
    },
    "/home": {
      "get": {
        "operationId": "HomeController_getHome",
        "parameters": [
          {
            "name": "childId",
            "required": false,
            "in": "query",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "name": "date",
            "required": false,
            "in": "query",
            "description": "홈 기준일. YYYY-MM-DD",
            "schema": {
              "example": "2026-05-13",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HomeDashboardDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": ["home"]
      }
    },
    "/notifications": {
      "get": {
        "operationId": "NotificationsController_list",
        "parameters": [
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "example": 20,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationListResponseDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": ["notifications"]
      }
    },
    "/notifications/read-all": {
      "patch": {
        "operationId": "NotificationsController_markAllRead",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MarkAllNotificationsReadResponseDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": ["notifications"]
      }
    },
    "/notifications/{id}/read": {
      "patch": {
        "operationId": "NotificationsController_markRead",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/NotificationListItemDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": ["notifications"]
      }
    },
    "/children/{id}": {
      "patch": {
        "operationId": "ChildrenController_updateChild",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateChildDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChildResponseDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": ["children"]
      },
      "delete": {
        "operationId": "ChildrenController_deleteChild",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "tags": ["children"]
      }
    }
  },
  "info": {
    "title": "Yougabell API",
    "description": "육아밸 domain API",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "ParentDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "홍길동",
            "minLength": 1,
            "maxLength": 30
          },
          "birthDate": {
            "type": "string",
            "example": "1990-01-01",
            "description": "ISO date (YYYY-MM-DD)"
          },
          "gender": {
            "type": "string",
            "enum": ["female", "male"]
          },
          "workStatus": {
            "type": "string",
            "enum": ["working", "full_time_caregiver"],
            "nullable": true,
            "description": "직장 유무 (선택)"
          }
        },
        "required": ["name", "birthDate", "gender"]
      },
      "ChildInputDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "김유스",
            "minLength": 1,
            "maxLength": 30
          },
          "birthDate": {
            "type": "string",
            "example": "2024-01-02"
          },
          "gender": {
            "type": "string",
            "enum": ["female", "male"]
          },
          "notes": {
            "type": "string",
            "description": "특이사항 자유 텍스트 (알레르기·발달 이슈 등). AI 챗봇 컨텍스트로 소비.",
            "maxLength": 1000
          }
        },
        "required": ["name", "birthDate", "gender"]
      },
      "AppUsageSlotDto": {
        "type": "object",
        "properties": {
          "dayOfWeek": {
            "type": "string",
            "enum": ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]
          },
          "slot": {
            "type": "string",
            "enum": ["morning", "afternoon", "evening", "night", "all_day"]
          }
        },
        "required": ["dayOfWeek", "slot"]
      },
      "CompleteOnboardingDto": {
        "type": "object",
        "properties": {
          "parent": {
            "$ref": "#/components/schemas/ParentDto"
          },
          "children": {
            "minItems": 1,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChildInputDto"
            }
          },
          "appUsage": {
            "description": "앱 사용 시간대 (요일 × 시간대). 빈 배열 허용 — 향후 정책 확정.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AppUsageSlotDto"
            }
          }
        },
        "required": ["parent", "children", "appUsage"]
      },
      "GenerateWeeklyReportsDto": {
        "type": "object",
        "properties": {
          "weekStart": {
            "type": "string",
            "example": "2026-05-04",
            "description": "생성할 주차의 월요일. YYYY-MM-DD. 없으면 직전 완료 주차"
          },
          "forceRegenerate": {
            "type": "boolean",
            "default": false,
            "description": "기존 리포트가 있을 때 삭제 후 재생성할지 여부"
          },
          "dryRun": {
            "type": "boolean",
            "default": false,
            "description": "생성 대상만 계산하고 DB 쓰기/알림 생성을 하지 않을지 여부"
          }
        }
      },
      "WeeklyReportSelectedChildDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "example": "김유스"
          },
          "ageLabel": {
            "type": "string",
            "example": "만3세"
          }
        },
        "required": ["id", "name", "ageLabel"]
      },
      "WeeklyReportHeadlineDto": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string",
            "example": "나는 잘하고 있는가?"
          },
          "title": {
            "type": "string",
            "example": "지금 충분히 잘하고 계십니다."
          },
          "body": {
            "type": "string",
            "nullable": true
          }
        },
        "required": ["question", "title", "body"]
      },
      "WeeklyReportDayDto": {
        "type": "object",
        "properties": {
          "weekday": {
            "type": "string",
            "enum": ["mon", "tue", "wed", "thu", "fri", "sat", "sun"]
          },
          "label": {
            "type": "string",
            "enum": ["월", "화", "수", "목", "금", "토", "일"]
          },
          "completedCount": {
            "type": "number",
            "minimum": 0
          },
          "completed": {
            "type": "boolean"
          }
        },
        "required": ["weekday", "label", "completedCount", "completed"]
      },
      "WeeklyReportMissionSummaryDto": {
        "type": "object",
        "properties": {
          "days": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WeeklyReportDayDto"
            }
          },
          "totalDurationSeconds": {
            "type": "number",
            "minimum": 0
          },
          "totalDurationLabel": {
            "type": "string",
            "example": "1시간 17분"
          },
          "childPositiveReactionRate": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          }
        },
        "required": [
          "days",
          "totalDurationSeconds",
          "totalDurationLabel",
          "childPositiveReactionRate"
        ]
      },
      "WeeklyReportKeywordDto": {
        "type": "object",
        "properties": {
          "rank": {
            "type": "number",
            "enum": [1, 2, 3]
          },
          "keyword": {
            "type": "string",
            "example": "공룡"
          }
        },
        "required": ["rank", "keyword"]
      },
      "WeeklyReportKeywordEmptyStateDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "아직 키워드가 충분하지 않아요"
          },
          "description": {
            "type": "string"
          }
        },
        "required": ["title", "description"]
      },
      "WeeklyReportBestMomentDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "order": {
            "type": "number",
            "minimum": 1
          },
          "label": {
            "type": "string",
            "example": "순수한 기쁨"
          },
          "title": {
            "type": "string"
          },
          "body": {
            "type": "string"
          }
        },
        "required": ["id", "order", "title", "body"]
      },
      "WeeklyReportInnerStateDto": {
        "type": "object",
        "properties": {
          "psychologicalEnergy": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "tipTitle": {
            "type": "string",
            "example": "기분 전환을 위한 팁"
          },
          "tipBody": {
            "type": "string"
          }
        },
        "required": ["psychologicalEnergy", "tipTitle"]
      },
      "WeeklyReportAiActionSuggestionDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "미래 행동 제안 (AI 기반)"
          },
          "body": {
            "type": "string"
          }
        },
        "required": ["title", "body"]
      },
      "WeeklyReportDetailDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "weekStart": {
            "type": "string",
            "example": "2026-05-04"
          },
          "weekEnd": {
            "type": "string",
            "example": "2026-05-10"
          },
          "generatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "headline": {
            "$ref": "#/components/schemas/WeeklyReportHeadlineDto"
          },
          "missionSummary": {
            "$ref": "#/components/schemas/WeeklyReportMissionSummaryDto"
          },
          "topKeywords": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WeeklyReportKeywordDto"
            }
          },
          "keywordEmptyState": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/WeeklyReportKeywordEmptyStateDto"
              }
            ]
          },
          "bestMoments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WeeklyReportBestMomentDto"
            }
          },
          "innerState": {
            "$ref": "#/components/schemas/WeeklyReportInnerStateDto"
          },
          "aiActionSuggestion": {
            "$ref": "#/components/schemas/WeeklyReportAiActionSuggestionDto"
          }
        },
        "required": [
          "id",
          "weekStart",
          "weekEnd",
          "generatedAt",
          "headline",
          "missionSummary",
          "topKeywords",
          "keywordEmptyState",
          "bestMoments",
          "innerState",
          "aiActionSuggestion"
        ]
      },
      "WeeklyReportEmptyStateDto": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string",
            "enum": [
              "no_mission_yet",
              "no_mission_for_week",
              "report_generation_pending"
            ]
          },
          "title": {
            "type": "string",
            "example": "아직 주간 리포트가 없습니다"
          },
          "description": {
            "type": "string"
          },
          "ctaLabel": {
            "type": "string",
            "example": "미션 시작하기"
          },
          "ctaHref": {
            "type": "string",
            "example": "/mission"
          }
        },
        "required": ["reason", "title", "description", "ctaLabel", "ctaHref"]
      },
      "WeeklyReportCurrentResponseDto": {
        "type": "object",
        "properties": {
          "selectedChild": {
            "$ref": "#/components/schemas/WeeklyReportSelectedChildDto"
          },
          "report": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/WeeklyReportDetailDto"
              }
            ]
          },
          "emptyState": {
            "nullable": true,
            "type": "object",
            "allOf": [
              {
                "$ref": "#/components/schemas/WeeklyReportEmptyStateDto"
              }
            ]
          }
        },
        "required": ["selectedChild", "report", "emptyState"]
      },
      "HomeChildDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string",
            "example": "김유스"
          },
          "birthDate": {
            "type": "string",
            "example": "2023-04-20",
            "description": "ISO date YYYY-MM-DD"
          },
          "ageLabel": {
            "type": "string",
            "example": "만3세"
          },
          "displayOrder": {
            "type": "number",
            "example": 0
          }
        },
        "required": ["id", "name", "birthDate", "ageLabel", "displayOrder"]
      },
      "HomeMoodDto": {
        "type": "object",
        "properties": {
          "level": {
            "type": "number",
            "enum": [1, 2, 3, 4, 5],
            "example": 4
          },
          "emoji": {
            "type": "string",
            "example": "😊"
          }
        },
        "required": ["level", "emoji"]
      },
      "HomeWeekDayDto": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "example": "2026-05-13",
            "description": "ISO date YYYY-MM-DD"
          },
          "weekdayLabel": {
            "type": "string",
            "enum": ["월", "화", "수", "목", "금", "토", "일"],
            "example": "수"
          },
          "dayOfMonth": {
            "type": "number",
            "example": 13
          },
          "isToday": {
            "type": "boolean"
          },
          "mood": {
            "$ref": "#/components/schemas/HomeMoodDto"
          },
          "missionCompleted": {
            "type": "boolean"
          }
        },
        "required": ["date", "weekdayLabel", "dayOfMonth", "isToday"]
      },
      "HomeWeekDto": {
        "type": "object",
        "properties": {
          "monthLabel": {
            "type": "string",
            "example": "5월"
          },
          "weekOfMonthLabel": {
            "type": "string",
            "example": "2주차"
          },
          "days": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/HomeWeekDayDto"
            }
          }
